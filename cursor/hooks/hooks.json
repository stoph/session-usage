{
  "version": 1,
  "hooks": {
    "sessionStart": [
      {
        "command": "${CURSOR_PLUGIN_ROOT}/scripts/log-usage.py"
      }
    ],
    "stop": [
      {
        "command": "${CURSOR_PLUGIN_ROOT}/scripts/log-usage.py"
      }
    ],
    "subagentStart": [
      {
        "command": "${CURSOR_PLUGIN_ROOT}/scripts/log-usage.py"
      }
    ],
    "subagentStop": [
      {
        "command": "${CURSOR_PLUGIN_ROOT}/scripts/log-usage.py"
      }
    ],
    "preCompact": [
      {
        "command": "${CURSOR_PLUGIN_ROOT}/scripts/log-usage.py"
      }
    ],
    "sessionEnd": [
      {
        "command": "${CURSOR_PLUGIN_ROOT}/scripts/log-usage.py"
      }
    ]
  }
}
